{
  "name": "tilbudstrolden-mcp",
  "version": "0.3.0",
  "type": "module",
  "description": "MCP server for Danish grocery deal hunting. Search offers, score recipes against current deals, and generate optimized shopping lists.",
  "author": "Olga Safonova",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/olgasafonova/tilbudstrolden-mcp.git"
  },
  "homepage": "https://github.com/olgasafonova/tilbudstrolden-mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "grocery",
    "deals",
    "tilbud",
    "danish",
    "etilbudsavis",
    "meal-planning",
    "shopping-list",
    "claude",
    "ai-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/server.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
